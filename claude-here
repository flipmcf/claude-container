#!/bin/bash
# Launch Claude Code sandbox in the current directory
# Install: ln -s ~/Projects/claude-sandbox/claude-here ~/bin/claude-here

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load sandbox-level .env (for ANTHROPIC_API_KEY or other global settings)
if [ -f "$SCRIPT_DIR/.env" ]; then
  . "$SCRIPT_DIR/.env"
fi

# Mount repo-level .claude.env if it exists (contains repo-specific tokens like GITHUB_TOKEN)
claude_env_args=""
if [ -f "$(pwd)/.claude.env" ]; then
  claude_env_args="-v $(pwd)/.claude.env:/tmp/.claude.env:ro"
fi

api_args=""
if [ -n "$ANTHROPIC_API_KEY" ]; then
  api_args="-e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY"
fi

docker run -it --rm --name claude-dev \
  -v "$(pwd):/workspace" \
  -v "$HOME/.claude:/tmp/.claude-host:ro" \
  -v "$HOME/.claude.json:/tmp/.claude.json:ro" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -e HOST_UID=$(id -u) \
  $claude_env_args \
  $api_args \
  claude-code-sandbox:latest
